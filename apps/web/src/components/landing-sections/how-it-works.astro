---
// How it works — numbered 4-step grid. Static (no reveal).
import { defaultLocale, type Locale } from '@/i18n/ui'
import { useTranslations } from '@/i18n/utils'

const locale = (Astro.currentLocale as Locale) ?? defaultLocale
const t = useTranslations(locale)

const steps = [
  { title: t('how.step1Title'), body: t('how.step1Body') },
  { title: t('how.step2Title'), body: t('how.step2Body') },
  { title: t('how.step3Title'), body: t('how.step3Body') },
  { title: t('how.step4Title'), body: t('how.step4Body') }
]
---

<section id="how-it-works" class="border-hairline scroll-mt-24 border-t">
  <div class="mx-auto max-w-6xl px-6 py-20 sm:py-28">
    <p class="eyebrow mb-4">{t('how.eyebrow')}</p>
    <h2 class="headline max-w-[20ch] text-[clamp(28px,4vw,40px)]">
      {t('how.titleLead')}<strong>{t('how.titleStrong')}</strong>
    </h2>

    <ol class="mt-12 grid gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-4">
      {
        steps.map((step, i) => (
          <li>
            <span class="text-faint font-mono text-[13px] tabular-nums">
              {String(i + 1).padStart(2, '0')}
            </span>
            <h3 class="mt-3 text-[16px] font-semibold tracking-[-0.01em]">
              {step.title}
            </h3>
            <p class="text-muted mt-2 text-[14px] leading-[1.6]">{step.body}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
