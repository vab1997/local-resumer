---
import { defaultLocale, type Locale } from '@/i18n/ui'
import { useTranslations } from '@/i18n/utils'
import { GITHUB } from '@/utils/links'
import GithubIcon from '@/components/github-icon.astro'

const locale = (Astro.currentLocale as Locale) ?? defaultLocale
const t = useTranslations(locale)
---

<section class="border-hairline scroll-mt-24 border-t">
  <div
    class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-5 px-6 py-14 sm:flex-row sm:items-center"
  >
    <div>
      <p class="text-ink text-[17px] font-semibold tracking-[-0.01em]">
        {t('oss.title')}
      </p>
      <p class="text-muted mt-1.5 max-w-lg text-[14px] leading-[1.55]">
        {t('oss.body')}
      </p>
    </div>
    <a
      href={GITHUB}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-ghost inline-flex shrink-0 items-center gap-2 px-4 py-2.5 text-sm font-medium"
    >
      <GithubIcon class="size-4.5" />
      {t('oss.cta')}
    </a>
  </div>
</section>
