---
// Placeholder landing — minimal text hero only. The real multi-section landing (demo,
// stat-row, steps, model cards, open-source band, CTA) lands in ticket 02. Renders both
// locales from the shared dictionary via Astro.currentLocale.
import { Puzzle } from '@lucide/astro'
import GithubIcon from '@/components/github-icon.astro'
import { defaultLocale, type Locale } from '@/i18n/ui'
import { useTranslations } from '@/i18n/utils'

const locale = (Astro.currentLocale as Locale) ?? defaultLocale
const t = useTranslations(locale)
---

<main class="mx-auto max-w-6xl px-6 py-28 sm:py-36">
  <p class="eyebrow mb-5">{t('hero.eyebrow')}</p>
  <h1
    class="text-muted max-w-3xl text-[clamp(40px,7vw,72px)] leading-[1.04] font-medium tracking-[-0.032em]"
  >
    {t('hero.titleLead')}<strong class="text-ink font-semibold"
      >{t('hero.titleStrong')}</strong
    >
  </h1>
  <p class="text-muted mt-6 max-w-xl text-[17px] leading-[1.6]">
    {t('hero.sub')}
  </p>

  <div class="mt-9 flex flex-wrap items-center gap-3">
    <a
      href="https://chromewebstore.google.com/detail/kchemponejhcgbnchebgmfonoddiklhn"
      target="_blank"
      rel="noopener noreferrer"
      class="btn-primary inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium"
    >
      <Puzzle class="size-4.5" />
      {t('nav.cta')}
    </a>
    <a
      href="https://github.com/vab1997/article-lens"
      target="_blank"
      rel="noopener noreferrer"
      class="btn-ghost inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium"
    >
      <GithubIcon class="size-4.5" />
      {t('footer.github')}
    </a>
  </div>
</main>
