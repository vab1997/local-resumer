---
import Layout from '@/layouts/Layout.astro'

const sections = [
  {
    title: 'What ArticleLens processes',
    body: 'The only content ArticleLens reads is the text of the article on the page you explicitly summarize. Nothing is read in the background: the extension injects its reader into a page only when you press Summarize, under a permission Chrome asks you to grant.'
  },
  {
    title: 'Local by default',
    body: 'By default the AI model runs entirely in your browser (WebGPU). The article, the summary, and everything in between stay on your device. The model weights are downloaded once from the Hugging Face Hub and cached by your browser — that download contains no information about you or the pages you visit.'
  },
  {
    title: 'Cloud mode is opt-in',
    body: 'If — and only if — you choose a cloud model and provide your own API key, the article text is sent directly from your browser to the provider you picked (OpenAI, Anthropic, or OpenRouter). ArticleLens marks this explicitly in the interface. No intermediary servers are involved: we do not operate any servers, and the text never passes through us. The provider handles that data under its own privacy policy.'
  },
  {
    title: 'API keys',
    body: "Your API keys are stored only in your browser's local extension storage (chrome.storage.local). They are sent exclusively to the corresponding provider as the authentication header of your own requests, and you can delete them at any time from the panel."
  },
  {
    title: 'What we never collect',
    body: 'No analytics, no telemetry, no accounts, no cookies, no browsing history, no personal data. ArticleLens has no backend. The "browsing history" permission Chrome mentions is used for exactly one thing: noticing you navigated away from a summarized page, so a summary is never attributed to the wrong article.'
  },
  {
    title: 'Changes',
    body: 'If this policy changes, the new version is published on this page with an updated date. The source code is public, so every claim above is verifiable.'
  },
  {
    title: 'Contact',
    body: 'Questions? Open an issue at <a href="https://github.com/vab1997/article-lens" target="_blank" rel="noopener noreferrer" class="font-bold text-white underline underline-offset-2">github.com/vab1997/article-lens</a>.'
  }
]
---

<Layout
  title="Privacy Policy — ArticleLens"
  description="ArticleLens privacy policy: local by default, cloud only if you opt in with your own key, zero telemetry."
  path="/privacy"
>
  <main class="mx-auto flex max-w-3xl flex-col gap-8 px-6 py-16 text-sm">
    <div>
      <h1 class="mb-2 text-2xl font-bold text-white">Privacy Policy</h1>
      <p class="text-zinc-500">Effective date: July 9, 2026</p>
    </div>

    <div class="space-y-8">
      {
        sections.map((section, i) => (
          <div class="flex gap-4">
            <span class="shrink-0 text-zinc-600">[{i + 1}]</span>
            <div>
              <p class="mb-1 font-bold text-white">{section.title}</p>
              <p
                class="text-muted-foreground/80 leading-relaxed"
                set:html={section.body}
              />
            </div>
          </div>
        ))
      }
    </div>
  </main>
</Layout>
