{
  "name": "local-resumer",
  "description": "Browser extension that summarizes the current article with an AI model running locally in the browser.",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "copy-ort": "node scripts/copy-ort.mjs",
    "postinstall": "node scripts/copy-ort.mjs && wxt prepare"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.2",
    "@ai-sdk/openai": "^4.0.3",
    "@huggingface/transformers": "^4.2.0",
    "@mozilla/readability": "^0.6.0",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tailwindcss/vite": "^4.3.1",
    "@wxt-dev/i18n": "^0.2.6",
    "ai": "^7.0.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.2.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.0",
    "wxt": "^0.20.27"
  }
}
